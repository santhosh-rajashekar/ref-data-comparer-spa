    {
      "canonical": "pl_statement_account_type",
      "label": "P&L State. Acct",
      "type": "coa_derived",
      "comparison_rule": "exact",
      "sources": {
        "COA": {
          "file": "COA_MASTER",
          "derivation": {
            "rule": "multi_condition",
            "description": "If G/L Account Type in (P,S,N) AND Account Group = 'ZSTA' → 'Y'. If G/L Account Type in (P,S,N) AND Account Group in (ZA30,ZA40,ZSEC,ZTEC) → 'X'. Else empty.",
            "conditions": [
              {
                "when": [
                  {
                    "col": "G/L Account Type",
                    "in": [
                      "P",
                      "S",
                      "N"
                    ]
                  },
                  {
                    "col": "Account Group",
                    "eq": "ZSTA"
                  }
                ],
                "result": "Y"
              },
              {
                "when": [
                  {
                    "col": "G/L Account Type",
                    "in": [
                      "P",
                      "S",
                      "N"
                    ]
                  },
                  {
                    "col": "Account Group",
                    "in": [
                      "ZA30",
                      "ZA40",
                      "ZSEC",
                      "ZTEC"
                    ]
                  }
                ],
                "result": "X"
              }
            ],
            "default": ""
          }
        },
        "FAQ": "P&L State. Acct",
        "DataPool": "pl_statement_account_type"
      }
